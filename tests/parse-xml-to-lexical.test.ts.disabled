/**
 * Tests for parseXmlToLexical function - validating Jamie's codeblock parsing improvements.
 * These tests ensure codeblock content extraction preserves whitespace formatting and
 * properly ignores Heretto processing instructions.
 *
 * Environment: vitest + jsdom + Lexical editor
 */

import { describe, it, expect, vi, beforeEach } from 'vitest';
import { parseXmlToLexical } from '../sync/parseXmlToLexical';
import { $createDitaCodeBlockNode } from '../components/DitaCodeBlockNode';

// Mock the DITA node creators to capture their calls
vi.mock('../components/DitaCodeBlockNode', () => ({
  $createDitaCodeBlockNode: vi.fn()
}));

vi.mock('../components/DitaOpaqueNode', () => ({
  $createDitaOpaqueNode: vi.fn()
}));

vi.mock('../components/DitaImageNode', () => ({
  $createDitaImageNode: vi.fn()
}));

vi.mock('../components/DitaPhRefNode', () => ({
  $createDitaPhRefNode: vi.fn()
}));

describe('parseXmlToLexical codeblock parsing improvements', () => {
  let mockEditor: any;
  let originMap: Map<string, any>;
  let capturedUpdateFunction: any;

  beforeEach(() => {
    // Mock editor that captures the update function for testing
    mockEditor = {
      update: vi.fn((updateFn: any, options?: any) => {
        capturedUpdateFunction = updateFn;
        // Execute the update function to test the parsing logic
        updateFn();
      })
    };
    originMap = new Map();

    // Reset all mocks
    vi.clearAllMocks();
  });

  describe('codeblock content extraction preserves whitespace formatting', () => {
    it('preserves leading whitespace in code content', () => {
      const xml = `<task>
        <taskbody>
          <codeblock>    function test() {
        console.log('indented');
    }</codeblock>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, mockEditor, originMap);
      expect(result).toBe(true);

      // Check that $createDitaCodeBlockNode was called with correct whitespace-preserved code
      expect($createDitaCodeBlockNode).toHaveBeenCalledWith(
        '    function test() {\n        console.log(\'indented\');\n    }',
        ''
      );
    });

    it('preserves trailing whitespace in code content', () => {
      const xml = `<task>
        <taskbody>
          <codeblock>function test() {
    return 'value';
}   </codeblock>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, mockEditor, originMap);
      expect(result).toBe(true);

      expect($createDitaCodeBlockNode).toHaveBeenCalledWith(
        'function test() {\n    return \'value\';\n}   ',
        ''
      );
    });

    it('preserves internal whitespace and line breaks exactly', () => {
      const xml = `<task>
        <taskbody>
          <codeblock>if (condition) {


    // Comment with spaces
    return value;
}</codeblock>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, mockEditor, originMap);
      expect(result).toBe(true);

      expect($createDitaCodeBlockNode).toHaveBeenCalledWith(
        'if (condition) {\n\n\n    // Comment with spaces\n    return value;\n}',
        ''
      );
    });

    it('preserves tab characters and mixed whitespace', () => {
      const xml = `<task>
        <taskbody>
          <codeblock>function\ttabbed() {
\t\treturn\t\t'mixed whitespace';
\t}</codeblock>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, mockEditor, originMap);
      expect(result).toBe(true);

      expect($createDitaCodeBlockNode).toHaveBeenCalledWith(
        'function\ttabbed() {\n\t\treturn\t\t\'mixed whitespace\';\n\t}',
        ''
      );
    });
  });

  describe('codeblock ignores Heretto processing instructions correctly', () => {
    it('filters out processing instructions while preserving code content', () => {
      const xml = `<task>
        <taskbody>
          <codeblock><?heretto-review id="r1" author="reviewer"?>function test() {
    console.log('code');
}<?heretto-review-end?></codeblock>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, mockEditor, originMap);
      expect(result).toBe(true);

      expect($createDitaCodeBlockNode).toHaveBeenCalledWith(
        'function test() {\n    console.log(\'code\');\n}',
        ''
      );

      // Verify processing instructions were filtered out
      const codeArgument = vi.mocked($createDitaCodeBlockNode).mock.calls[0][0];
      expect(codeArgument).not.toContain('<?heretto-review');
      expect(codeArgument).not.toContain('<?heretto-review-end');
    });

    it('filters multiple processing instructions from different locations', () => {
      const xml = `<task>
        <taskbody>
          <codeblock><?pi1?>const x = <?pi2?>'value'<?pi3?>;
console.log(x);<?pi4?></codeblock>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, mockEditor, originMap);
      expect(result).toBe(true);

      expect($createDitaCodeBlockNode).toHaveBeenCalledWith(
        'const x = \'value\';\nconsole.log(x);',
        ''
      );

      // Verify all processing instructions were filtered
      const codeArgument = vi.mocked($createDitaCodeBlockNode).mock.calls[0][0];
      expect(codeArgument).not.toContain('<?pi');
    });

    it('preserves content from nested elements while ignoring processing instructions', () => {
      const xml = `<task>
        <taskbody>
          <codeblock><?review?><b>function</b> test() {
    return <?comment?><i>'value'</i>;
}<?end-review?></codeblock>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, mockEditor, originMap);
      expect(result).toBe(true);

      expect($createDitaCodeBlockNode).toHaveBeenCalledWith(
        'function test() {\n    return \'value\';\n}',
        ''
      );

      // Verify processing instructions were filtered while element content preserved
      const codeArgument = vi.mocked($createDitaCodeBlockNode).mock.calls[0][0];
      expect(codeArgument).not.toContain('<?');
    });
  });

  describe('codeblock language attribute extraction', () => {
    it('extracts outputclass attribute as language identifier', () => {
      const xml = `<task>
        <taskbody>
          <codeblock outputclass="javascript">function test() {}</codeblock>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, mockEditor, originMap);
      expect(result).toBe(true);

      expect($createDitaCodeBlockNode).toHaveBeenCalledWith(
        'function test() {}',
        'javascript'
      );
    });

    it('uses empty string as language when no outputclass is present', () => {
      const xml = `<task>
        <taskbody>
          <codeblock>function test() {}</codeblock>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, mockEditor, originMap);
      expect(result).toBe(true);

      expect($createDitaCodeBlockNode).toHaveBeenCalledWith(
        'function test() {}',
        ''
      );
    });

    it('handles outputclass with complex language specifications', () => {
      const xml = `<task>
        <taskbody>
          <codeblock outputclass="language-typescript">const x: string = 'test';</codeblock>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, mockEditor, originMap);
      expect(result).toBe(true);

      expect($createDitaCodeBlockNode).toHaveBeenCalledWith(
        'const x: string = \'test\';',
        'language-typescript'
      );
    });
  });

  describe('codeblock regression tests for previous textContent extraction', () => {
    it('handles empty codeblock correctly', () => {
      const xml = `<task>
        <taskbody>
          <codeblock></codeblock>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, editor, originMap);
      expect(result).toBe(true);

      editor.read(() => {
        const root = $getRoot();
        const children = root.getChildren();
        const codeblock = children.find(child => child.__type === 'dita-codeblock');
        expect(codeblock).toBeDefined();
        expect(codeblock.__code).toBe('');
      });
    });

    it('handles codeblock with only whitespace', () => {
      const xml = `<task>
        <taskbody>
          <codeblock>

  </codeblock>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, editor, originMap);
      expect(result).toBe(true);

      editor.read(() => {
        const root = $getRoot();
        const children = root.getChildren();
        const codeblock = children.find(child => child.__type === 'dita-codeblock');
        expect(codeblock).toBeDefined();
        expect(codeblock.__code).toBe('   \n    \n  ');
      });
    });

    it('validates improvement over old textContent extraction method', () => {
      // This test shows that the new extraction method preserves structure
      // that the old xmlNode.textContent approach would flatten
      const xml = `<task>
        <taskbody>
          <codeblock>before<?pi?>middle<span>after</span>end</codeblock>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, editor, originMap);
      expect(result).toBe(true);

      editor.read(() => {
        const root = $getRoot();
        const children = root.getChildren();
        const codeblock = children.find(child => child.__type === 'dita-codeblock');
        expect(codeblock).toBeDefined();
        // New method: processing instructions filtered, element content preserved
        expect(codeblock.__code).toBe('beforemiddleafterend');
        // Old textContent method would have given: 'beforemiddleafterend' but couldn't filter PIs
      });
    });
  });

  describe('edge cases and error handling', () => {
    it('handles malformed XML gracefully by skipping sync', () => {
      const malformedXml = '<task><codeblock>unclosed';

      const result = parseXmlToLexical(malformedXml, editor, originMap);
      expect(result).toBe(false);

      editor.read(() => {
        const root = $getRoot();
        const children = root.getChildren();
        expect(children).toHaveLength(0);
      });
    });

    it('handles codeblock nested in various DITA structures', () => {
      const xml = `<task>
        <taskbody>
          <steps>
            <step>
              <cmd>Run this code:</cmd>
              <info>
                <codeblock>echo "Hello World"</codeblock>
              </info>
            </step>
          </steps>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, editor, originMap);
      expect(result).toBe(true);

      editor.read(() => {
        const root = $getRoot();
        // The codeblock should be processed and preserved
        const allNodes = root.getChildren();
        expect(allNodes.some(node => node.__type === 'dita-codeblock')).toBe(true);
      });
    });

    it('validates originMap is not affected by codeblock processing', () => {
      const xml = `<task>
        <taskbody>
          <p>Before codeblock</p>
          <codeblock>code content</codeblock>
          <p>After codeblock</p>
        </taskbody>
      </task>`;

      const result = parseXmlToLexical(xml, editor, originMap);
      expect(result).toBe(true);

      // Origin map should contain entries for paragraphs but not codeblocks
      expect(originMap.size).toBeGreaterThan(0);
      const originEntries = Array.from(originMap.values());
      expect(originEntries.some(entry => entry.tag === 'p')).toBe(true);
    });
  });
});